{
  "expo": {
    "name": "Nexa",
    "slug": "Nexa",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "firstapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.berke.nexa2",
      "icon": "./assets/images/Nexa-icon-comp.icon",
      "infoPlist": {
        "NSCameraUsageDescription": "Nexa utilise la caméra pour prendre des photos et vidéos de vos stories.",
        "NSMicrophoneUsageDescription": "Nexa utilise le micro pour enregistrer le son de vos vidéos.",
        "NSPhotoLibraryUsageDescription": "Nexa accède à votre galerie pour choisir des photos et vidéos à publier en story.",
        "NSPhotoLibraryAddUsageDescription": "Nexa peut enregistrer des médias dans votre galerie.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#128C7E"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.arzwebconcept.firstapp",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 250,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 250,
            "resizeMode": "contain",
            "backgroundColor": "#0f1f1e"
          }
        }
      ],
      "expo-secure-store",
      "expo-video",
      [
        "expo-camera",
        {
          "cameraPermission": "Nexa utilise la caméra pour prendre des photos et vidéos de vos stories.",
          "microphonePermission": "Nexa utilise le micro pour enregistrer le son de vos vidéos.",
          "recordAudioAndroid": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ca07cd71-3522-49e7-911f-695fbcbf1556"
      }
    }
  }
}
